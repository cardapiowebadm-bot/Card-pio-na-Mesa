rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Is user logged in
    function isLoggedIn() {
      return request.auth != null;
    }

    // Helper: Get user's profile document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper: Check if user has profile data
    function hasUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Helper: Check if user belongs to the target restaurant
    function isMemberOf(restaurantId) {
      return isLoggedIn() && hasUserData() && getUserData().restaurantId == restaurantId;
    }

    // Helper: Check user role
    function hasRole(role) {
      return isLoggedIn() && hasUserData() && getUserData().role == role;
    }

    // Restaurants
    match /restaurants/{restaurantId} {
      allow read: if true; // Publicly readable for cardápio
      allow write: if isLoggedIn() && (
        // Only owner or manager of this restaurant can edit
        isMemberOf(restaurantId) && (getUserData().role == 'owner' || getUserData().role == 'manager')
      ) || (
        // Allow creating a new restaurant during sign-up
        request.resource.data.ownerId == request.auth.uid
      );
    }

    // Users (Employees/Owners)
    match /users/{userId} {
      allow read: if isLoggedIn() && (
        request.auth.uid == userId || 
        (request.auth.uid != userId && hasUserData() && getUserData().restaurantId == resource.data.restaurantId)
      );
      allow create: if isLoggedIn();
      allow update, delete: if isLoggedIn() && (
        request.auth.uid == userId || 
        (request.auth.uid != userId && hasUserData() && getUserData().restaurantId == resource.data.restaurantId && (getUserData().role == 'owner' || getUserData().role == 'manager'))
      );
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true; // Public menu access
      allow create, update: if isLoggedIn() && isMemberOf(request.resource.data.restaurantId);
      allow delete: if isLoggedIn() && isMemberOf(resource.data.restaurantId);
    }

    // Products
    match /products/{productId} {
      allow read: if true; // Public menu access
      allow create, update: if isLoggedIn() && isMemberOf(request.resource.data.restaurantId);
      allow delete: if isLoggedIn() && isMemberOf(resource.data.restaurantId);
    }

    // Tables
    match /tables/{tableId} {
      allow read: if true; // Publicly readable to select table
      allow create: if (isLoggedIn() && isMemberOf(request.resource.data.restaurantId)) || 
                     (request.resource.data.status == 'occupied' && 
                      request.resource.data.keys().hasAll(['id', 'number', 'status', 'restaurantId', 'createdAt']) &&
                      exists(/databases/$(database)/documents/restaurants/$(request.resource.data.restaurantId)));
      allow update: if (isLoggedIn() && isMemberOf(resource.data.restaurantId)) || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) && (
                       (resource.data.status == 'free' && request.resource.data.status == 'occupied') ||
                       (resource.data.status == 'occupied' && request.resource.data.status in ['calling', 'billing']) ||
                       (resource.data.status == 'calling' && request.resource.data.status in ['occupied', 'billing']) ||
                       (resource.data.status == 'billing' && request.resource.data.status in ['occupied', 'calling'])
                     ));
      allow delete: if isLoggedIn() && isMemberOf(resource.data.restaurantId);
    }

    // Table Sessions
    match /tableSessions/{sessionId} {
      allow read: if true; // Publicly readable to track current table session
      allow create: if (isLoggedIn() && isMemberOf(request.resource.data.restaurantId)) ||
                     (request.resource.data.status == 'active' && 
                      request.resource.data.keys().hasAll(['id', 'tableId', 'tableNumber', 'restaurantId', 'customerName', 'customerPhone', 'status', 'createdAt']) &&
                      get(/databases/$(database)/documents/tables/$(request.resource.data.tableId)).data.restaurantId == request.resource.data.restaurantId);
      allow update: if (isLoggedIn() && isMemberOf(resource.data.restaurantId)) ||
                     (resource.data.status == 'active' &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentMethod', 'paymentStatus']) && 
                      request.resource.data.paymentStatus == 'pending' && 
                      request.resource.data.paymentMethod in ['pix', 'card']);
      allow delete: if isLoggedIn() && isMemberOf(resource.data.restaurantId);
    }

    // Orders
    match /orders/{orderId} {
      allow read: if true; // Publicly readable to track own order status
      allow create: if (isLoggedIn() && isMemberOf(request.resource.data.restaurantId)) ||
                     (request.resource.data.status == 'pending' && 
                      request.resource.data.keys().hasAll(['id', 'tableSessionId', 'tableId', 'tableNumber', 'restaurantId', 'items', 'subtotal', 'serviceTax', 'total', 'status', 'createdAt', 'updatedAt', 'customerName', 'customerPhone']) &&
                      get(/databases/$(database)/documents/tableSessions/$(request.resource.data.tableSessionId)).data.restaurantId == request.resource.data.restaurantId &&
                      get(/databases/$(database)/documents/tableSessions/$(request.resource.data.tableSessionId)).data.status == 'active');
      allow update: if isLoggedIn() && isMemberOf(resource.data.restaurantId); // Only employees can update order status
      allow delete: if isLoggedIn() && isMemberOf(resource.data.restaurantId) && getUserData().role == 'owner';
    }

    // Waiter Calls
    match /waiterCalls/{callId} {
      allow read: if true; // Publicly readable to check call status
      allow create: if (isLoggedIn() && isMemberOf(request.resource.data.restaurantId)) ||
                     (request.resource.data.status == 'pending' && 
                      request.resource.data.keys().hasAll(['id', 'tableSessionId', 'tableId', 'tableNumber', 'restaurantId', 'reason', 'status', 'createdAt']) &&
                      request.resource.data.reason in ['water', 'napkin', 'service', 'bill', 'other'] &&
                      get(/databases/$(database)/documents/tableSessions/$(request.resource.data.tableSessionId)).data.restaurantId == request.resource.data.restaurantId &&
                      get(/databases/$(database)/documents/tableSessions/$(request.resource.data.tableSessionId)).data.status == 'active');
      allow update: if isLoggedIn() && isMemberOf(resource.data.restaurantId); // Employees can resolve calls
      allow delete: if isLoggedIn() && isMemberOf(resource.data.restaurantId) && getUserData().role == 'owner';
    }

    // Waiters
    match /waiters/{waiterId} {
      allow read: if true; // Publicly readable for validation during login/first access
      allow create, update: if isLoggedIn() && isMemberOf(request.resource.data.restaurantId);
      allow delete: if isLoggedIn() && isMemberOf(resource.data.restaurantId) && (getUserData().role == 'owner' || getUserData().role == 'manager');
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isLoggedIn() && isMemberOf(resource.data.restaurantId);
      allow create: if (isLoggedIn() && isMemberOf(request.resource.data.restaurantId)) ||
                     (request.resource.data.status == 'unread' && 
                      request.resource.data.keys().hasAll(['restaurantId', 'type', 'message', 'status', 'referenceId', 'tableNumber', 'createdAt']) &&
                      request.resource.data.type in ['new_order', 'waiter_call', 'payment_request']);
      allow update: if isLoggedIn() && isMemberOf(resource.data.restaurantId);
      allow delete: if isLoggedIn() && isMemberOf(resource.data.restaurantId);
    }
  }
}
